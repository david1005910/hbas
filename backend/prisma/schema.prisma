generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id          String    @id @default(uuid())
  name        String    @db.VarChar(200)
  description String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  episodes    Episode[]

  @@map("projects")
}

model BibleBook {
  id            Int          @id @default(autoincrement())
  nameKo        String       @db.VarChar(100)
  nameHe        String       @db.VarChar(100)
  nameEn        String       @db.VarChar(100)
  orderNo       Int          @unique
  totalChapters Int
  episodes      Episode[]
  verses        BibleVerse[]

  @@map("bible_books")
}

// 구절별 히브리어 원문 + 언리얼 엔진 3D Actor 태그 매핑
model BibleVerse {
  id         String    @id @default(uuid())
  bookId     Int
  book       BibleBook @relation(fields: [bookId], references: [id])
  chapter    Int
  verse      Int
  hebrewText String    @db.Text         // BHS 히브리어 원문 (RTL)
  koreanText String    @db.Text         // 한국어 번역 (개역개정)
  actorTag   String?   @db.VarChar(200) // 언리얼 엔진 Actor 태그 (3D 오브젝트 연동)
  // embedding: pgvector vector(768) — Gemini text-embedding-004 (managed via raw SQL)
  createdAt  DateTime  @default(now())

  @@unique([bookId, chapter, verse])
  @@index([bookId, chapter])
  @@map("bible_verses")
}

model Episode {
  id             String             @id @default(uuid())
  projectId      String
  project        Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  bibleBookId    Int
  bibleBook      BibleBook          @relation(fields: [bibleBookId], references: [id])
  titleKo        String             @db.VarChar(300)
  titleHe        String?            @db.VarChar(300)
  verseRange     String?            @db.VarChar(100)
  sceneCount     Int                @default(5)
  animStyle      String?            @db.VarChar(100)
  targetDuration Int                @default(300)
  status         EpisodeStatus      @default(DRAFT)
  narrationUrl   String?            @db.VarChar(500)
  bgmUrl         String?            @db.VarChar(500)  // 에피소드별 커스텀 BGM
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  contents       GeneratedContent[]
  keyframes      SceneKeyframe[]
  videoClips     SceneVideoClip[]
  characterImages CharacterImage[]

  @@map("episodes")
}

enum EpisodeStatus {
  DRAFT
  IN_PROGRESS
  COMPLETE
}

model GeneratedContent {
  id          String      @id @default(uuid())
  episodeId   String
  episode     Episode     @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  contentType ContentType
  content     String      @db.Text
  version     Int         @default(1)
  aiModel     String?     @db.VarChar(100)
  createdAt   DateTime    @default(now())

  @@map("generated_contents")
}

enum ContentType {
  SCRIPT
  ANIM_PROMPT
  SRT_KO
  SRT_HE
  SRT_VI
  YT_META
}

model SceneKeyframe {
  id           String           @id @default(uuid())
  episodeId    String
  episode      Episode          @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  sceneNumber  Int
  promptUsed   String?          @db.Text
  imageUrl     String?          @db.VarChar(500)
  resolution   String           @default("1920x1080") @db.VarChar(20)
  isSelected   Boolean          @default(false)
  nbModel      String?          @db.VarChar(100)
  createdAt    DateTime         @default(now())
  videoClips   SceneVideoClip[]

  @@map("scene_keyframes")
}

model SceneVideoClip {
  id          String          @id @default(uuid())
  keyframeId  String
  keyframe    SceneKeyframe   @relation(fields: [keyframeId], references: [id], onDelete: Cascade)
  episodeId   String
  episode     Episode         @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  sceneNumber Int
  veoJobId    String?         @db.VarChar(500)
  status      VideoClipStatus @default(PENDING)
  clipUrl     String?         @db.VarChar(500)
  clipGcsUri  String?         @db.VarChar(1000)  // Veo 3.1 GCS URI (연장에 사용)
  extendCount Int             @default(0)         // 연장 횟수
  subClipUrl  String?         @db.VarChar(500)   // 자막 삽입된 클립
  narrClipUrl String?         @db.VarChar(500)   // 나레이션 합성된 클립
  durationSec Int             @default(8)
  seqOrder    Int             @default(0)  // 0=독립 클립, 1~N=연속 체인 순서
  seqTotal    Int             @default(0)  // 연속 체인 총 수 (0=독립)
  createdAt   DateTime        @default(now())

  @@map("scene_video_clips")
}

enum VideoClipStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// 캐릭터 이미지 (일관성 유지용)
model CharacterImage {
  id          String   @id @default(uuid())
  episodeId   String
  episode     Episode  @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  name        String   @db.VarChar(100)    // 캐릭터 이름
  description String?  @db.VarChar(500)    // 캐릭터 설명
  imageUrl    String   @db.VarChar(500)    // 저장된 이미지 URL
  orderIndex  Int      @default(0)         // 표시 순서
  createdAt   DateTime @default(now())

  @@map("character_images")
}
