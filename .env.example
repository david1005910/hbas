# ============================
# HBAS v2 Environment Variables
# ============================

# Google AI Studio (Gemini + Nano Banana)
GOOGLE_AI_API_KEY=AIzaSy...
GEMINI_MODEL=gemini-2.5-flash
NANO_BANANA_MODEL=gemini-2.5-flash-image

# Google Cloud / Vertex AI (Veo 3.1)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/app/service-account.json
VEO_MODEL=veo-3.1-generate-001

# Database
DATABASE_URL=postgresql://hbas:your_password@postgres:5432/hbas_db
DB_PASSWORD=your_secure_password

# Redis
REDIS_URL=redis://redis:6379

# Storage
KEYFRAME_STORAGE_PATH=/app/storage/keyframes
VIDEO_STORAGE_PATH=/app/storage/videos

# App
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000
MAX_TOKENS=8192
CACHE_TTL_SECONDS=86400
