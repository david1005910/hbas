# ============================
# HBAS v2 Environment Variables
# ============================

# Google AI Studio (Gemini + Nano Banana)
GOOGLE_AI_API_KEY=AIzaSy...
GEMINI_MODEL=gemini-2.5-flash
NANO_BANANA_MODEL=gemini-2.5-flash-image

# Google Cloud / Vertex AI (Veo 3.1)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/app/service-account.json
VEO_MODEL=veo-3.1-generate-preview

# Veo 3.1 영상 연장 설정
# GCS 버킷: Veo 3.1 출력 저장 및 영상 연장에 필요 (없으면 8초 고정)
# 버킷 생성: gcloud storage buckets create gs://[PROJECT_ID]-veo --location=us-central1
GCS_OUTPUT_BUCKET=gs://your-gcp-project-id-veo/
# 씬당 목표 영상 길이(초): 8+7×n 형태 (15=1회, 22=2회, 29=3회 연장)
TARGET_SCENE_DURATION=22

# Database
DATABASE_URL=postgresql://hbas:your_password@postgres:5432/hbas_db
DB_PASSWORD=your_secure_password

# Redis
REDIS_URL=redis://redis:6379

# Storage
KEYFRAME_STORAGE_PATH=/app/storage/keyframes
VIDEO_STORAGE_PATH=/app/storage/videos
AUDIO_STORAGE_PATH=/app/storage/audio
BGM_PATH=/app/storage/bgm/gregorian.mp3

# App
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000
MAX_TOKENS=8192
CACHE_TTL_SECONDS=86400
